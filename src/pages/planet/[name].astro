--- 
// @ts-nocheck
import "../../styles/detail.css";

// Bron: https://api.le-systeme-solaire.net/en/
export async function getStaticPaths() {
  const response = await fetch("https://api.le-systeme-solaire.net/rest/bodies/", {
    headers: {
      Authorization: `Bearer ${import.meta.env.SOLAR_API_KEY}`,
    },
  });

  const data = await response.json();

  return data.bodies
    .filter((body) => body.isPlanet)
    .map((planet) => ({
      params: {
        name: planet.englishName.toLowerCase(),
      },
    }));
}

const { name } = Astro.params;

const response = await fetch("https://api.le-systeme-solaire.net/rest/bodies/", {
  headers: {
    Authorization: `Bearer ${import.meta.env.SOLAR_API_KEY}`,
  },
});

const data = await response.json();

const planet = data.bodies.find(
  (body) => body.isPlanet && body.englishName.toLowerCase() === name
);

if (!planet) {
  throw new Error("Planet not found");
}

const textureMap = {
  Mercury: "/images/planets/mercury.png",
  Venus: "/images/planets/venus.png",
  Earth: "/images/planets/earth.png",
  Mars: "/images/planets/mars.png",
  Jupiter: "/images/planets/jupiter.png",
  Saturn: "/images/planets/saturn.png",
  Uranus: "/images/planets/uranus.png",
  Neptune: "/images/planets/neptune.png",
};

const texture = textureMap[planet.englishName];
const moonCount = planet.moons ? planet.moons.length : 0;
--- 

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{planet.englishName}</title>
  </head>

  <body>
    <main>
      <a class="back-link" href="/">↩ Back to solar system</a>

      <section class="hero">
        <div class="planet-image-wrapper">
          {texture ? (
            <img class="planet-image" src={texture} alt={planet.englishName} />
          ) : (
            <div>{planet.englishName}</div>
          )}
        </div>

        <div>
          <h1>{planet.englishName}</h1>
          <p class="subtitle">
            Explore key awesome about {planet.englishName}, including its size, gravity,
            distance from the Sun, orbital period, and more.
          </p>
        </div>
      </section>

      <section class="grid">
        <article class="card">
          <p class="label">Mean radius</p>
          <p class="value">{planet.meanRadius} km</p>
        </article>

        <article class="card">
          <p class="label">Gravity</p>
          <p class="value">{planet.gravity} m/s²</p>
        </article>

        <article class="card">
          <p class="label">Distance from Sun</p>
          <p class="value">{planet.semimajorAxis.toLocaleString()} km</p>
        </article>

        <article class="card">
          <p class="label">Moons</p>
          <p class="value">{moonCount}</p>
        </article>
      </section>

      <section class="facts">
        <h2>Extra facts</h2>
        <ul>
          <li>Orbital {planet.sideralOrbit} days</li>
          <li>Rotation period: {planet.sideralRotation} hours</li>
          <li>Density: {planet.density} g/cm³</li>
          <li>Escape velocity: {planet.escape} m/s</li>
          <li>Axial tilt: {planet.axialTilt}°</li>
          <li>Average temperature: {planet.avgTemp} K</li>
        </ul>
      </section>
    </main>
  </body>
</html>