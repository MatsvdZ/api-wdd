--- 
// @ts-nocheck
import "../../styles/detail.css";


export async function getStaticPaths() {
  const response = await fetch("https://api.le-systeme-solaire.net/rest/bodies/", {
    headers: {
      Authorization: `Bearer ${import.meta.env.SOLAR_API_KEY}`,
    },
  });

  const data = await response.json();

  const planets = data.bodies
    .filter((body) => body.isPlanet)
    .map((planet) => ({
      params: {
        name: planet.englishName.toLowerCase(),
      },
    }));

  return planets;
}

const { name } = Astro.params;

const response = await fetch("https://api.le-systeme-solaire.net/rest/bodies/", {
  headers: {
    Authorization: `Bearer ${import.meta.env.SOLAR_API_KEY}`,
  },
});

const data = await response.json();

const planet = data.bodies.find(
  (body) => body.isPlanet && body.englishName.toLowerCase() === name
);

if (!planet) {
  throw new Error("Planet not found");
}
--- 

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="/styles/detail.css" />
    <title>{planet.englishName}</title>
  </head>
  <body>
    <main>
      <a href="/">← Back to solar system</a>

      <h1>{planet.englishName}</h1>

      <ul>
        <li><strong>Radius:</strong> {planet.meanRadius} km</li>
        <li><strong>Gravity:</strong> {planet.gravity} m/s²</li>
        <li><strong>Distance from Sun:</strong> {planet.semimajorAxis} km</li>
        <li><strong>Orbital period:</strong> {planet.sideralOrbit} days</li>
        <li><strong>Rotation period:</strong> {planet.sideralRotation} hours</li>
        <li><strong>Density:</strong> {planet.density} g/cm³</li>
        <li><strong>Moons:</strong> {planet.moons ? planet.moons.length : 0}</li>
      </ul>
    </main>
  </body>
</html>
