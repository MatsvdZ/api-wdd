---
// @ts-nocheck
import BaseLayout from "../layouts/BaseLayout.astro";
import Controls from "../components/Controls.astro";
import "../styles/index.css";

const response = await fetch("https://api.le-systeme-solaire.net/rest/bodies/", {
  headers: {
    Authorization: `Bearer ${import.meta.env.SOLAR_API_KEY}`,
  },
});

const data = await response.json();

const textureMap = {
  Mercury: "/images/planets/mercury.png",
  Venus: "/images/planets/venus.png",
  Earth: "/images/planets/earth.png",
  Mars: "/images/planets/mars.png",
  Jupiter: "/images/planets/jupiter.png",
  Saturn: "/images/planets/saturn.png",
  Uranus: "/images/planets/uranus.png",
  Neptune: "/images/planets/neptune.png",
};

const planets = data.bodies
  .filter((body) => body.isPlanet)
  .map((planet) => ({
    name: planet.englishName,
    slug: planet.englishName.toLowerCase(),
    radius: planet.meanRadius,
    distance: planet.semimajorAxis,
    orbitTime: planet.sideralOrbit,
    sideralRotation: planet.sideralRotation,
    texture: textureMap[planet.englishName],
  }))
  .sort((a, b) => a.distance - b.distance);

const moons = data.bodies
  .filter(
    (body) =>
      body.bodyType === "Moon" &&
      body.aroundPlanet?.planet?.toLowerCase() === "terre"
  )
  .map((moon) => ({
    name: moon.englishName,
    aroundPlanet: moon.aroundPlanet?.planet,
    radius: moon.meanRadius,
    orbitTime: moon.sideralOrbit,
  }));

console.log(moons.filter((moon) => moon.name.toLowerCase().includes("moon")));
console.log(moons.slice(0, 20));
---

<BaseLayout title="Our Solar System">
  <Controls />

  <canvas id="solar-system"></canvas>

  <script define:vars={{ planets, moons }}>
    window.planets = planets;
    window.moons = moons;
  </script>

  <script type="module" src="/canvas.js" is:inline></script>
</BaseLayout>